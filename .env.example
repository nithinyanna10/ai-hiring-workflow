# Local: `docker compose up -d` in repo root (Postgres on host port 54329). Do not reuse Supabase’s 54322 unless you intend to share that instance.
DATABASE_URL="postgresql://postgres:postgres@localhost:54329/hiring_workflow"
DIRECT_URL="postgresql://postgres:postgres@localhost:54329/hiring_workflow"
# Must match dev server port (see apps/web package.json `dev` script; default 4730 avoids 3000/5000/8080 clashes)
NEXT_PUBLIC_APP_URL="http://localhost:4730"
# Email: `mock` = no Resend calls (best for demos). With `resend`, unverified domains and sandbox recipient limits auto-fallback to mock delivery so flows don’t fail.
EMAIL_PROVIDER="mock"
# Use a domain you verified in Resend (https://resend.com/domains). Gmail/Yahoo etc. cannot be the "from" address; leave unset to use onboarding@resend.dev.
EMAIL_FROM=""
RESEND_API_KEY=""
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.2"
SCREENING_SCORE_THRESHOLD="75"
SLACK_PROVIDER="mock"
SLACK_BOT_TOKEN=""
SLACK_TEAM_ID=""
SLACK_HR_CHANNEL_ID=""
SLACK_WELCOME_CHANNEL_ID=""
# Optional: receive email when a candidate completes offer signing (in addition to activity events).
ADMIN_ALERT_EMAIL=""
