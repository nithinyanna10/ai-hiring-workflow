{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@hiring-workflow/shared": ["packages/shared/index.ts"],
      "@hiring-workflow/ai-engine": ["packages/ai-engine/index.ts"],
      "@hiring-workflow/workflow-engine": ["packages/workflow-engine/index.ts"]
    }
  }
}
